# ===========================================
# ОБЩИЕ НАСТРОЙКИ
# ===========================================
NODE_ENV=development
PORT=3001

# ===========================================
# БАЗА ДАННЫХ (PostgreSQL)
# ===========================================
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://animeuser:animepassword@localhost:5432/animestream?schema=public"

# Прямые параметры для подключения (альтернатива DATABASE_URL, если нужно)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=animestream
DB_USER=animeuser
DB_PASSWORD=animepassword

# ===========================================
# REDIS (Кэширование и сессии)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Формат URL для клиентов, поддерживающих его
REDIS_URL="redis://localhost:6379"

# TTL для кэша внешних API (в секундах)
CACHE_TTL=3600

# ===========================================
# JWT АВТОРИЗАЦИЯ
# ===========================================
# Сгенерируйте надежные случайные строки для продакшена
# Можно использовать: openssl rand -base64 32
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-prod-12345"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-prod-67890"

# Время жизни токенов
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ===========================================
# ВНЕШНИЕ API (Аниме данные)
# ===========================================
# Пример: Anilist, Kitsu, Shikimori и т.д.
# Оставьте пустым, если используете мок-данные
ANIME_API_KEY=""
ANIME_API_URL="https://graphql.anilist.co"
ANIME_API_ENABLED=true

# ===========================================
# БЕЗОПАСНОСТЬ И CORS
# ===========================================
# Разрешенные источники для CORS (через запятую)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000"

# Rate Limiting (запросов в минуту)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# ЛОГИРОВАНИЕ
# ===========================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# ===========================================
# ФРОНТЕНД (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_NAME="AnimeStream"
NEXT_PUBLIC_DEFAULT_THEME=dark

# ===========================================
# АДМИН ПАНЕЛЬ
# ===========================================
# Данные для создания первого администратора при первом запуске
ADMIN_EMAIL="admin@animestream.local"
ADMIN_PASSWORD="AdminPassword123!"
ADMIN_NAME="Super Admin"

# ===========================================
# ХРАНЕНИЕ МЕДИА (опционально)
# ===========================================
# Если будете хранить постеры/баннеры локально
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=10

# S3 совместимое хранилище (если нужно)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
